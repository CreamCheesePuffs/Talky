  <property name="styleSheet">
   <string notr="true">/* ======================
   全局 / 主窗口背景
   ====================== */
QMainWindow {
    background: #F5F6F7;
}

QWidget#centralWidget {
    background: #F5F6F7;
}

QWidget {
    background: #F5F6F7;
    color: #222;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 13px;
}

/* 让容器类不要被 QWidget 默认背景影响（更稳） */
QFrame, QGroupBox {
    background: transparent;
}

/* ======================
   左侧 navPanel
   ====================== */
QWidget#navPanel {
    background: #F5F6F7;
    border-right: 1px solid #E9EAEC;
}

QToolButton {
    background: transparent;
    border: none;
    border-radius: 10px;
    padding: 8px;
}

QToolButton:hover {
    background: rgba(0,0,0,0.06);
}

QToolButton:pressed {
    background: rgba(0,0,0,0.10);
}

/* ======================
   中间 listPanel
   ====================== */
QWidget#listPanel {
    background: #F5F6F7;
    border-right: 1px solid #E9EAEC;
}

/* 搜索/输入框通用 */
QLineEdit {
    background: #EBEBEB;
    border: 1px solid #E6E7EA;
    border-radius: 10px;
    padding: 8px 10px;
    selection-background-color: #2A82FF;
}

QLineEdit:focus {
    border: 1px solid rgba(42,130,255,0.55);
}

/* 会话列表 */
QListWidget#chatList {
    background: transparent;
    border: none;
    outline: none;
    padding: 6px;                 /* 列表整体内边距 */
}

QListWidget#chatList::item {
    padding: 0px;
    margin: 2px 0px;
    border: none;
}

QListWidget#chatList::item:hover,
QListWidget#chatList::item:selected {
    background: transparent;   /* 选中背景由 ChatItem 自身控制 */
}

/* ======================
   右侧 chatPanel
   ====================== */
QWidget#chatPanel {
    background: #F5F6F7;
}

/* 顶部 headerBar */
QWidget#headerBar {
    background: #F5F6F7;
    border-bottom: 1px solid #E9EAEC;
}

/* 消息区：QListWidget + viewport 都强制白底，避免灰块 */
QListWidget#messageList {
    background: #F5F6F7;
    border: none;
    outline: none;
}

QListWidget#messageList::item {
    background: transparent;
    border: none;
}

QListWidget#messageList:focus {
    outline: none;
}


QWidget#ChatItemClass {
    background: transparent;
    border-radius: 10px;
}

QWidget#ChatItemClass[hover=&quot;true&quot;] {
    background: rgba(34,117,230,0.2);
}

QWidget#ChatItemClass[selected=&quot;true&quot;] {
    background: rgba(34,117,230,0.2);
}

/* 关键：viewport 才是真正绘制背景的地方 */
QListWidget#messageList QAbstractScrollArea::viewport {
    background: #F5F6F7;
}

/* 底部输入区 */
QWidget#composerBar {
    background: #F5F6F7;
    border-top: 1px solid #E9EAEC;
}

/* 在白底区域，输入框保持白底（避免被 QWidget 全局灰覆盖） */
QWidget#chatPanel QLineEdit {
    background: #F5F6F7;
}

/* 发送按钮：QQ 蓝 */
QPushButton#sendButton {
    background: #2A82FF;
    color: white;
    border: none;
    border-radius: 10px;
    padding: 8px 14px;
}

QPushButton#sendButton:hover {
    background: #2275E6;
}

QPushButton#sendButton:pressed {
    background: #1B62C7;
}

/* ======================
   滚动条（更像 QQ）
   ====================== */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 2px 2px 2px 2px;
}

QScrollBar::handle:vertical {
    background: rgba(0,0,0,0.15);
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(0,0,0,0.25);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: transparent;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}
</string>

   <string notr="true">/* 会话 item 整体 */
QWidget#ChatItemClass {
    background: transparent;
}

/* 头像（如果你用 QLabel 显示 pixmap） */
QLabel#avatarLabel {
    border-radius: 20px;
}

/* 昵称 */
QLabel#nameLabel {
    font-size: 14px;
    font-weight: 600;
    color: #222;
}

/* 预览 */
QLabel#previewLabel {
    font-size: 12px;
    color: rgba(0,0,0,0.55);
}

/* 时间 */
QLabel#timeLabel {
    font-size: 11px;
    color: rgba(0,0,0,0.45);
}

/* 未读 badge */
QLabel#unreadBadge {
    background: #FF3B30;
    color: white;
    border-radius: 9px;
    font-size: 11px;
    font-weight: 600;
    padding: 0px;
}

